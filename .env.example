
# ============================================================
# FIREBASE CONFIGURATION - ✅ READY FOR TESTING
# ============================================================
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ============================================================
# BYBIT API (FREE - No API keys needed for public data!)
# ============================================================
BYBIT_API_KEY=optional_not_needed_for_public_data
BYBIT_API_SECRET=optional_not_needed_for_public_data
BYBIT_TESTNET=false

# ============================================================
# DERIV API (FREE - Already configured!)
# ============================================================
DERIV_APP_ID=113343

# ============================================================
# TELEGRAM BOT - ✅ AUTO-DETECTS GROUPS/CHANNELS
# ============================================================
# Your Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN= 

 

# Owner Chat ID (unlimited AI requests)
OWNER_CHAT_ID= 

# Broadcast Channel ID (optional - sends ALL signals here without subscription)
# To get channel ID: Add bot as admin, send any message, check logs for chat ID
# Format: Use negative numbers for channels/groups (e.g., -1001234567890)
# Leave empty to disable broadcast channel
BROADCAST_CHANNEL_ID= 

# NO NEED TO SET CHAT_ID FOR SUBSCRIPTIONS!
# Bot automatically detects groups/channels when you:
# 1. Add bot to group/channel as admin
# 2. Send /subscribe command
# Bot will save and send signals to all subscribed chats

# ============================================================
# TRADING SETTINGS
# ============================================================
TRENDING_THRESHOLD_MIN=5.0
TRENDING_THRESHOLD_MAX=50.0
RSI_OVERSOLD_LEVEL=25.0
RSI_OVERBOUGHT_LEVEL=75.0
CANDLE_HISTORY_SIZE=1000
MONITORING_UPDATE_INTERVAL=1800

# ============================================================
# TRADING PAIRS
# ============================================================
# CRYPTO: Auto-fetched daily at 00:00 UTC (top 5 bullish + 5 bearish)
# FOREX: Static list below
# DERIV: Static list below

FOREX_PAIRS=frxEURUSD,frxAUDUSD,frxUSDJPY,frxGBPUSD,frxUSDCAD,frxXAUUSD
DERIV_PAIRS=1HZ50V,1HZ100V,R_100,1HZ25V,1HZ10V,R_10

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL= 

# ============================================================
# DNS CONFIGURATION (Fix for corporate DNS blocking)
# ============================================================
NODE_OPTIONS=--dns-result-order= 

# ============================================================
# PROXY CONFIGURATION (Bypass DNS & Geo-restrictions)
# ============================================================

BINANCE_PROXY_URL=
BYBIT_PROXY_URL= 


PROXY_URL=

# ============================================================
# API KEYS FOR TECHNICAL ANALYSIS & NEWS
# ============================================================

# Alpha Vantage (500 requests/day) - Get free key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY= 

# Twelve Data (800 requests/day) - Get free key: https://twelvedata.com/
TWELVE_DATA_API_KEY= 

# Finnhub (60 calls/minute) - Get free key: https://finnhub.io/
FINNHUB_API_KEY= 

# FCS API (500 requests/month) - Get free key: https://fcsapi.com/register
FCS_API_KEY=

# NewsAPI (100 requests/day) - Get free key: https://newsapi.org/
NEWS_API_KEY=

# ============================================================
# OPEN ROUTER AI (Multiple keys for fallback, comma-separated)
# ============================================================
# Get free keys: https://openrouter.ai/
# Add multiple keys separated by commas for higher limits
# Example: OPENROUTER_API_KEYS=key1,key2,key3
OPENROUTER_API_KEYS=